{
  "schema_version": "0.1",
  "graph_name": "contemplative-neuroscience-graph",
  "description": "Knowledge graph mapping contemplative practices to phenomenological states, neural signatures, brain networks, and cognitive mechanisms, with citation provenance and explicit evidence-strength annotation. Designed to interoperate with darshana-graph and buddhist-philosophy-graph as a companion ontology (shared node-id conventions, same evidence_strength vocabulary).",
  "node_types": {
    "Tradition": {
      "properties": [
        "id",
        "name",
        "lineage_family",
        "region"
      ],
      "example": {
        "id": "trad:nyingma_dzogchen",
        "name": "Nyingma Dzogchen",
        "lineage_family": "Tibetan Vajrayana",
        "region": "Tibet"
      }
    },
    "Practice": {
      "properties": [
        "id",
        "name",
        "aliases",
        "phenomenological_focus",
        "traditional_objective"
      ],
      "example": {
        "id": "prac:hwadu_investigation",
        "name": "Hwadu (kanhwa Seon) investigation",
        "aliases": [
          "kong-an investigation",
          "critical phrase meditation"
        ],
        "phenomenological_focus": "sustained generative doubt (uisim)",
        "traditional_objective": "breakthrough (gyeonseong) via resolution of great doubt"
      }
    },
    "PhenomenologicalState": {
      "properties": [
        "id",
        "name",
        "tradition_specific_term",
        "description"
      ],
      "example": {
        "id": "phen:rigpa",
        "name": "Rigpa",
        "tradition_specific_term": "rig pa (Tib.)",
        "description": "nondual, open, self-luminous awareness"
      }
    },
    "NeuralSignature": {
      "properties": [
        "id",
        "name",
        "modality",
        "description",
        "measurement_notes"
      ],
      "example": {
        "id": "sig:dan_dmn_anticorrelation",
        "name": "DAN-DMN anti-correlation",
        "modality": "fMRI",
        "description": "stable anti-correlated activity between Dorsal Attention Network and Default Mode Network",
        "measurement_notes": "task-based fMRI, resting-state contrast"
      }
    },
    "NetworkNode": {
      "properties": [
        "id",
        "name",
        "abbreviation",
        "anatomical_location"
      ],
      "example": {
        "id": "net:precuneus",
        "name": "Precuneus",
        "abbreviation": "PCu",
        "anatomical_location": "medial parietal lobule"
      }
    },
    "CognitiveMechanism": {
      "properties": [
        "id",
        "name",
        "framework",
        "description"
      ],
      "example": {
        "id": "mech:signal_to_noise",
        "name": "Signal-to-noise ratio hypothesis",
        "framework": "predictive processing / affective neuroscience",
        "description": "sensory and verbal gating raises the relative salience of self-generated affective signal"
      }
    },
    "Citation": {
      "properties": [
        "id",
        "authors",
        "year",
        "venue",
        "doi_or_url",
        "sample_size",
        "study_design"
      ],
      "example": {
        "id": "cite:chowdhury_2024_neuroimage",
        "authors": "Chowdhury et al.",
        "year": 2024,
        "venue": "NeuroImage",
        "doi_or_url": "10.1016/j.neuroimage.2024.120973",
        "sample_size": "n=1 (intensively sampled)",
        "study_design": "case study, multimodal 7T fMRI-EEG"
      }
    },
    "CognitiveOperation": {
      "properties": [
        "id",
        "name",
        "description"
      ],
      "description": "A layer sitting between Practice and NeuralSignature. Different traditions can share a cognitive operation (and therefore show similar low-level neural signatures) while remaining phenomenologically and doctrinally distinct — this is what makes Young et al. 2021's null result on cross-tradition power-spectra differences intelligible rather than a contradiction of the taxonomy.",
      "example": {
        "id": "cogop:attentional_narrowing",
        "name": "Attentional narrowing",
        "description": "progressive restriction of attention to a single fixed object"
      }
    },
    "Finding": {
      "properties": [
        "id",
        "name",
        "description",
        "implication"
      ],
      "description": "An empirical result recorded as its own node (rather than folded silently into an edge) specifically so it can be attached as a caveat to claims it complicates, e.g. an orthogonality claim that a null result argues against.",
      "example": {
        "id": "finding:young2021_no_power_spectra_diff",
        "name": "No cross-tradition power-spectra differences",
        "description": "six-tradition EEG comparison found no significant power-spectra differences between meditation styles",
        "implication": "cautions against treating traditions as having cleanly separable EEG signatures"
      }
    }
  },
  "edge_types": {
    "PRACTICED_WITHIN": {
      "from": "Practice",
      "to": "Tradition"
    },
    "PRODUCES": {
      "from": "Practice",
      "to": "PhenomenologicalState"
    },
    "CORRELATES_WITH": {
      "from": "PhenomenologicalState",
      "to": "NeuralSignature",
      "properties": [
        "evidence_strength"
      ]
    },
    "MEDIATED_BY": {
      "from": "NeuralSignature",
      "to": "NetworkNode",
      "properties": [
        "evidence_strength"
      ]
    },
    "EXPLAINED_BY": {
      "from": "NeuralSignature",
      "to": "CognitiveMechanism",
      "properties": [
        "evidence_strength"
      ]
    },
    "EVIDENCED_BY": {
      "from": "*",
      "to": "Citation"
    },
    "ORTHOGONAL_TO": {
      "from": "Practice",
      "to": "Practice",
      "description": "taxonomically distinct per the orthogonality criterion"
    },
    "ANALOGOUS_TO": {
      "from": "Practice",
      "to": "Practice",
      "properties": [
        "confidence"
      ],
      "description": "used when a practice's own neural evidence is thin and a nearer-evidenced practice is used as a provisional proxy"
    },
    "PART_OF": {
      "from": "*",
      "to": "Tradition"
    },
    "EMPLOYS": {
      "from": "Practice",
      "to": "CognitiveOperation",
      "description": "the cognitive-operations axis proposed as a companion to the practice-level taxonomy; multiple practices/traditions can share an operation"
    },
    "CAVEATED_BY": {
      "from": "*",
      "to": "Finding",
      "description": "attaches an empirical result as a qualifier to any claim or edge it complicates, without deleting the original claim"
    }
  },
  "evidence_strength_vocabulary": [
    "high",
    "moderate",
    "low",
    "theoretical_only"
  ],
